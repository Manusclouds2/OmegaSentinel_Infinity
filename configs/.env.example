# LOPUTH JOSEEPH OMEGA - Environment Configuration Template
# Copy this file to .env and fill in your values
# Production-ready configuration with quantum-safe cryptography and advanced threat intelligence

# ===== SENTINEL-UG CLIENT CONFIGURATION =====
CLIENT_ID=omega-client-001
CLIENT_TOKEN=your_unique_client_token_here
QUANTUM_ORCHESTRATOR_URL=wss://orchestrator.sentinel.ug/ws/client/omega-client-001
PROTECTION_LEVEL=omega_full
NETWORK_MODE=bridge

# Client Quantum Features
CHRONOS_POLYMORPHISM_ENABLED=true
DIMENSIONAL_FOLDS_COUNT=256

# Client Protection Settings
AUTO_UPDATE_ENABLED=true
HEARTBEAT_INTERVAL=5s
THREAT_REPORTING=true

# ===== QUANTUM CONFIGURATION =====
QUANTUM_MASTER_KEY=generated_master_key_here
QUANTUM_ENTROPY_SEED=entropy_seed_placeholder
CHRONOS_POLYMORPHISM_ENABLED=true
DIMENSIONAL_FOLDS_COUNT=256

# ===== DATABASE =====
POSTGRES_DB=sentinel_omega
POSTGRES_USER=quantum_admin
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://quantum_admin:change-this-password@postgres:5432/sentinel_omega

# ===== REDIS CACHE =====
REDIS_PASSWORD=change-this-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:change-this-password@redis:6379

# ===== DASHBOARD CONFIGURATION =====
DASHBOARD_SECRET_KEY=your-secret-key-here-min-64-chars
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8443
DASHBOARD_SSL_CERT=/ssl/fullchain.pem
DASHBOARD_SSL_KEY=/ssl/privkey.pem
OMEGA_SECRET=your-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here-min-32-chars

# ===== BIO-DIGITAL AUTHENTICATION =====
EEG_SENSOR_ENABLED=false
STRESS_THRESHOLD=0.85
SILENT_ERASURE_ENABLED=true

# ===== THREAT INTELLIGENCE =====
VIRUSTOTAL_API_KEY=your_virustotal_key_here
MITRE_ATTACK_API_ENABLED=true
DARK_WEB_MONITORING=true
SHODAN_API_KEY=your_shodan_key_here
MAXMIND_API_KEY=your_maxmind_key_here

# ===== CLOUD INTEGRATION =====
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1

# ===== PAYMENT PROCESSING =====
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===== COMPLIANCE & DATA GOVERNANCE =====
GDPR_COMPLIANT=true
DATA_RETENTION_DAYS=30
AUTO_DATA_ERASURE=true

# ===== EMAIL NOTIFICATIONS =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@omega.local

# ===== MONITORING & OBSERVABILITY =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ALERTMANAGER_ENABLED=true
GRAFANA_PASSWORD=change-this-password

# ===== DEPLOYMENT SETTINGS =====
DEPLOYMENT_MODE=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ===== AUTO-SCALING =====
AUTO_SCALING_ENABLED=true
MAX_REPLICAS=100

# ===== FIREWALL SETTINGS =====
SCAN_ROOT=/app/scan
FIREWALL_MODE=passive
PACKET_CAPTURE=true
THREAT_LEVEL_THRESHOLD=high

# ===== APPLICATION SETTINGS =====
MAX_LOGIN_ATTEMPTS=5
SESSION_TIMEOUT=3600
JWT_EXPIRY=3600
MASTER_KEY_PATH=configs/quantum-keys/master.key
